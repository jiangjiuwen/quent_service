# Core paths
QUANT_BASE_DIR=.
QUANT_DATA_DIR=./data
QUANT_LOG_DIR=./logs
QUANT_WEB_DIR=./web
QUANT_WEB_ASSETS_DIR=./web/assets
QUANT_DB_PATH=./data/a_stock_quant.db

# API
QUANT_API_HOST=0.0.0.0
QUANT_API_PORT=8000
QUANT_API_WORKERS=1

# Sync
QUANT_BATCH_SIZE=100
QUANT_SYNC_HOUR=15
QUANT_SYNC_MINUTE=30

# Data window
QUANT_HISTORY_YEARS=15
QUANT_START_YEAR=2010
QUANT_END_YEAR=2025

# Logging
QUANT_LOG_LEVEL=INFO
QUANT_LOG_FORMAT="{time:YYYY-MM-DD HH:mm:ss} | {level} | {name} | {message}"

# Data sources
QUANT_SOURCE_AKSHARE_ENABLED=true
QUANT_SOURCE_BAOSTOCK_ENABLED=true
QUANT_SOURCE_TUSHARE_ENABLED=false
